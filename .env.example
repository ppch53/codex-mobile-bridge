
NODE_ENV=development
LOG_LEVEL=info

CODEX_TRANSPORT=auto
CODEX_BINARY=codex
CODEX_HOME=C:\Users\<user>\.codex
CODEX_WS_URL=ws://127.0.0.1:4500
CODEX_WS_AUTH_TOKEN_FILE=

BRIDGE_DATA_DIR=%APPDATA%\CodexMobileBridge
BRIDGE_LOG_DIR=%LOCALAPPDATA%\CodexMobileBridge\logs
ALLOWED_WORKSPACES=C:\CodexBridgeTest;D:\Projects

TELEGRAM_BOT_TOKEN=replace_me
ALLOWED_TELEGRAM_USER_IDS=123456789
TELEGRAM_POLLING=true

WEB_ENABLED=true
WEB_BIND_HOST=127.0.0.1
WEB_PORT=8765
WEB_REQUIRE_PAIRING=true

APPROVAL_TIMEOUT_SECONDS=300
DANGEROUS_COMMAND_CONFIRM=true
MAX_TELEGRAM_MESSAGE_CHARS=3800
REDACT_SECRETS=true
